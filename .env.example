# ── Seguridad ──
# Genera una con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de Datos (PostgreSQL) ──
DB_ENGINE=django.db.backends.postgresql
DB_NAME=inmo_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Celery & Redis ──
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=true

# ── Inteligencia Artificial ──
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── JWT ──
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Correo (SMTP) ──
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@inmohelpdesk.local

# Ruta opcional a npm (Windows: C:\\Program Files\\nodejs\\npm.cmd)
#NPM_BIN_PATH=
